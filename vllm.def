Bootstrap: docker
From: nvidia/cuda:11.8.0-base-ubuntu22.04

%post
    # Prevent interactive timezone prompts during installation
    export DEBIAN_FRONTEND=noninteractive
    
    echo "Installing OS dependencies..."
    apt-get update -y
    apt-get install -y python3.10 python3-pip python3.10-distutils curl git
    
    # Make python3 command point to python3.10
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1
    
    echo "Upgrading pip..."
    python3 -m pip install --no-cache-dir --upgrade pip
    
    echo "Installing vLLM for CUDA 11.8..."
    python3 -m pip install --no-cache-dir https://github.com/vllm-project/vllm/releases/download/v0.10.1.1/vllm-0.10.1.1+cu118-cp38-abi3-manylinux1_x86_64.whl --extra-index-url https://download.pytorch.org/whl/cu118
    

    python3 -m pip install --no-cache-dir evaluate seqeval tqdm openai transformers==4.53 tokenizers

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
